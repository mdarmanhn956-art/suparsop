
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Suparsop Electronics</title>
<style>
body{margin:0;font-family:Arial,sans-serif;background:#f4f4f4;}
a{text-decoration:none;color:inherit;}
button{cursor:pointer;}
header{background:#131921;color:white;padding:15px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;}
header h1{margin:0;font-size:24px;}
.search-box{flex:1;margin:0 20px;}
.search-box input{width:100%;padding:8px;border-radius:4px;border:none;font-size:16px;}
.hero{background:#232f3e;color:white;text-align:center;padding:60px 20px;}
.hero h2{font-size:36px;margin:10px;}
.hero p{font-size:20px;margin:10px;}
.hero button{background:#f0c14b;color:#111;border:none;padding:12px 25px;font-size:18px;border-radius:4px;margin-top:15px;}
.container{padding:40px;}
.container h2{text-align:center;font-size:28px;margin-bottom:30px;}
.products{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;}
.card{background:white;padding:15px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1);text-align:center;}
.card img{width:100%;border-radius:8px;}
.card h3{margin:10px 0 5px;}
.card p{margin:5px 0;color:#555;}
.card .price{font-weight:bold;margin:5px 0;color:#B12704;}
.card .rating{color:#FFA41C;margin:5px 0;}
.card button{background:#25D366;color:white;padding:10px 15px;border:none;border-radius:4px;margin-top:8px;}
footer{background:#131921;color:white;text-align:center;padding:25px;margin-top:30px;}
.footer-links a{margin:0 10px;color:white;font-size:16px;}
</style>
</head>
<body>

<!-- Header -->
<header>
<h1>Suparsop</h1>
<div class="search-box">
<input type="text" placeholder="Search Electronics...">
</div>
<div class="cart">
<a href="#"><img src="https://cdn-icons-png.flaticon.com/512/263/263142.png" width="30"></a>
</div>
</header>

<!-- Hero Banner -->
<section class="hero">
<h2>20% OFF Today!</h2>
<p>Shop Best Electronics Online</p>
<button onclick="window.location.href='#products'">Shop Now</button>
</section>

<!-- Products -->
<div class="container" id="products">
<h2>Our Products</h2>
<div class="products">

<div class="card">
<img src="https://images.unsplash.com/photo-1580910051077-1477a5b6b3bb?auto=format&fit=crop&w=250&q=80" alt="Portable Water Flosser">
<h3>Portable Water Flosser</h3>
<p>Powerful dental cleaning device</p>
<p class="price">৳1,250</p>
<p class="rating">⭐⭐⭐⭐☆</p>
<a href="https://wa.me/8801318180222"><button>Order on WhatsApp</button></a>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1606813903064-8d8e015be207?auto=format&fit=crop&w=250&q=80" alt="Smart LED Light">
<h3>Smart LED Light</h3>
<p>Energy saving smart lighting</p>
<p class="price">৳850</p>
<p class="rating">⭐⭐⭐⭐⭐</p>
<a href="https://wa.me/8801318180222"><button>Order on WhatsApp</button></a>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1588776814546-3a46d2c37f24?auto=format&fit=crop&w=250&q=80" alt="Kitchen Electric Gadget">
<h3>Kitchen Electric Gadget</h3>
<p>Modern smart kitchen tool</p>
<p class="price">৳1,500</p>
<p class="rating">⭐⭐⭐⭐☆</p>
<a href="https://wa.me/8801318180222"><button>Order on WhatsApp</button></a>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1565058513-7473ecdb16cd?auto=format&fit=crop&w=250&q=80" alt="Wireless Earbuds">
<h3>Wireless Earbuds</h3>
<p>High quality sound & long battery</p>
<p class="price">৳2,000</p>
<p class="rating">⭐⭐⭐⭐⭐</p>
<a href="https://wa.me/8801318180222"><button>Order on WhatsApp</button></a>
</div>

</div>
</div>

<!-- Footer -->
<footer>
<p>Contact Us: 01318180222 | WhatsApp</p>
<div class="footer-links">
<a href="#">Home</a> | <a href="#products">Products</a> | <a href="#">Contact</a>
</div>
<p>© 2026 Suparsop Electronics</p>
</footer>

</body>
</html>

